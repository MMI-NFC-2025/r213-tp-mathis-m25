---
import Layout from '../../layouts/Layout.astro';
import { allAgents } from '../../backend.js';

// Récupération de la liste des agents depuis PocketBase
const agents = await allAgents();
---

<Layout title="Liste des agents">
    <h1 class="text-2xl font-bold my-8">Nos Agents Immobiliers</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {agents.map((agent) => (
            <a href={`/agents/${agent.id}`} class="border p-4 rounded-lg hover:shadow-lg transition">
                <h2 class="text-xl font-semibold">{agent.nom} {agent.prenom}</h2>
                <p class="text-gray-600">{agent.email}</p>
                <span class="text-blue-500 underline">Voir ses offres →</span>
            </a>
        ))}
    </div>
</Layout>