---
import Layout from '../../layouts/Layout.astro';
import { allArtists } from '../../backend.mjs';

const artists = await allArtists();
---

<Layout title="Liste des Artistes">
    <h1 class="text-2xl font-bold mb-6">Nos Artistes</h1>
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {artists.map((artist) => (
            <li class="border p-4 rounded-lg shadow-sm">
                <a href={`/artistes/${artist.id}`} class="text-blue-600 hover:underline">
                    {artist.name || `${artist.first_name} ${artist.last_name}`}
                </a>
            </li>
        ))}
    </ul>
</Layout>