---
import '../styles/global.css';
import OffreCard from '../components/OffreCard.astro';

// 1. Importation de la fonction getOffres depuis ton fichier backend
import { getOffres } from '../js/backend.mjs';

// 2. Appel de la fonction pour récupérer les vraies données de PocketBase
const offres = await getOffres();
---

<html lang="fr">
    <head>
		<meta charset="UTF-8" /> <meta name="viewport" content="width=device-width" />
        <title>Nos Offres</title>
    </head>
    <body>
        <h1 class="text-2xl font-bold p-4">Page des offres</h1>
        
        <button id="favori-button" class="bg-blue-500 text-white p-2 m-4 rounded">
            Afficher les Favoris
        </button>

        <div id="offres-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 p-4">
    		{offres.map((offre) => (
        		<OffreCard {...offre} />
    		))}
		</div>

        <script>
            const button = document.getElementById('favori-button');
            let showOnlyFavorites = false;

            button.addEventListener('click', () => {
                showOnlyFavorites = !showOnlyFavorites;
                // Sélection de tous les éléments ayant la classe .offre
                const cartes = document.querySelectorAll('.offre');

                cartes.forEach((carte) => {
                    // Vérification de l'attribut data-favori
                    const isFavori = carte.getAttribute('data-favori') === 'true';
                    
                    // On caste en HTMLElement pour éviter les erreurs si tu es en mode strict
                    const element = carte as HTMLElement;

                    if (showOnlyFavorites) {
                        element.style.display = isFavori ? 'block' : 'none';
                        button.textContent = 'Afficher tout';
                    } else {
                        element.style.display = 'block';
                        button.textContent = 'Afficher les Favoris';
                    }
                });
            });
        </script>
    </body>
</html>